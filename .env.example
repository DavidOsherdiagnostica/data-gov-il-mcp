# ─── Transport ──────────────────────────────────────────────────────────────
# Which transport to default to. Use "stdio" for Claude Desktop, "http" for remote.
TRANSPORT=stdio

# ─── HTTP Server (only used when TRANSPORT=http) ────────────────────────────
PORT=3664
HOST=0.0.0.0
# Allowed CORS origins. Comma-separated. Use '*' for development only.
CORS_ORIGIN=*

# ─── HTTP Hardening ──────────────────────────────────────────────────────────
# Set to "true" or a hop-count (e.g. 1) when behind a reverse proxy (nginx, Caddy, ALB).
# Required for rate limiting to use the real client IP instead of the proxy IP.
# TRUST_PROXY=false

# Rate limiting window in milliseconds (default: 1 minute). Set to 0 to disable.
# RATE_LIMIT_WINDOW_MS=60000
# Maximum requests per window per IP (default: 120). Set to 0 to disable.
# RATE_LIMIT_MAX=120

# DNS rebinding protection for HTTP mode.
# Defaults to localhost/loopback only when unset.
# For public or Docker deployments, set the public host(s) explicitly.
# Entries may be hostnames, IPs, or host:port pairs.
# ALLOWED_HOSTS=localhost,127.0.0.1,::1,your-mcp-server.example.com

# Optional browser Origin allowlist. When unset, CORS_ORIGIN is used if it is not "*".
# ALLOWED_ORIGINS=https://your-client.example.com

# ─── Logging ────────────────────────────────────────────────────────────────
# One of: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# ─── CKAN API ───────────────────────────────────────────────────────────────
CKAN_BASE_URL=https://data.gov.il/api/3/action
# Default request timeout in milliseconds
CKAN_TIMEOUT_MS=10000
# Timeout for heavier datastore_search queries
CKAN_SEARCH_TIMEOUT_MS=15000

# ─── Cache ──────────────────────────────────────────────────────────────────
# TTL for cached responses in milliseconds (5 minutes default)
CACHE_TTL_MS=300000
CACHE_MAX_ITEMS=500

# ─── Authentication ─────────────────────────────────────────────────────────
# Authentication mode: "none" | "apikey" | "oauth"
# - none:   No authentication (default, suitable for stdio and local dev)
# - apikey: Bearer token validated against API_KEYS list below
# - oauth:  JWT Bearer token validated against OAuth 2.1 JWKS endpoint
AUTH_MODE=none

# Required when AUTH_MODE=apikey — comma-separated list of valid keys
# API_KEYS=key1,key2,secret_key_here

# Required when AUTH_MODE=oauth
# OAUTH_ISSUER=https://your-auth-server.example.com
# OAUTH_AUDIENCE=https://your-mcp-server.example.com
# OAUTH_JWKS_URI=https://your-auth-server.example.com/.well-known/jwks.json
# Canonical MCP resource URL used in RFC 8707 Resource Indicators.
# Usually the public Streamable HTTP endpoint, including /mcp.
# OAUTH_RESOURCE_SERVER=https://your-mcp-server.example.com/mcp

# ─── Service Identity (optional overrides, defaults from package.json) ───────
# SERVICE_NAME=data-gov-il
# SERVICE_VERSION=3.0.0

# ─── Optional MCP Client Features ────────────────────────────────────────────
# Disabled by default because MCP client support varies.
#
# Enable Elicitation-dependent interactive tool flows.
# When true, find_datasets exposes interactive=true and supported clients
# may show a clarification form to narrow broad result sets.
MCP_ENABLE_ELICITATION=false
#
# Enable Sampling-dependent tools.
# When true, summarize_dataset is registered and can ask supported clients
# to run a model-generated dataset summary. Unsupported clients still get fallback metadata.
MCP_ENABLE_SAMPLING=false

# ─── Runtime environment ─────────────────────────────────────────────────────
NODE_ENV=production
